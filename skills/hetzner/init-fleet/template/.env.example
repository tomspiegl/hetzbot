# {{FLEET_NAME}} — session credentials.
# Copy to .env, populate from your personal vault, NEVER commit.

# Where the hetzbot framework lives. Sibling clone is the default.
HETZBOT_ROOT=../hetzbot

# --- Hetzner Cloud ---
HCLOUD_TOKEN=

# --- Hetzner Object Storage (tfstate backend + restic repo) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
OS_REGION=fsn1
OS_ENDPOINT=https://fsn1.your-objectstorage.com
OS_BUCKET={{FLEET_NAME}}-state

# --- Backups ---
RESTIC_PASSWORD=

# --- Console fallback (cloud-init writes this to the host; SSH won't accept it) ---
CONSOLE_ROOT_PASSWORD=

# --- Public hosts ---
# Apex of the Hetzner DNS zone. Leave blank if no public hosts.
DOMAIN=

# --- Per-host, single-use (regenerate per host bootstrap) ---
TAILSCALE_AUTHKEY=
